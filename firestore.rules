rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Permite lectura pública para que el Invoice Tracker pueda
    // leer los datos de clientes desde TECH-TICKETS sin auth.
    // La escritura sigue requiriendo autenticación (técnicos en campo).
    match /{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
